# Скопируй этот файл в .env и подставь свои значения.
# .env не должен попадать в git — добавь его в .gitignore.

# --- PostgreSQL ---
POSTGRES_DB=contracts
POSTGRES_USER=contracts_app
POSTGRES_PASSWORD=change_me

# Строка подключения, которую использует backend.
# Хост "db" — это имя сервиса из docker-compose.yml, Docker сам его резолвит
# во внутренней сети контейнеров, отдельно прописывать IP не нужно.
DATABASE_URL=postgresql+psycopg://contracts_app:change_me@db:5432/contracts

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_too
# Хост "minio" — аналогично, имя сервиса из docker-compose.yml
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=contracts

# --- Доступ (Basic Auth) ---
# "логин:пароль,логин2:пароль2" — каждый через запятую. Пусто = без
# авторизации (открыто всем, кто знает URL — только для локальной
# разработки). На сервере ОБЯЗАТЕЛЬНО задать хотя бы одну пару.
# Пример для себя + бета-тестера:
# AUTH_USERS=mishel:StrongPass123,betatester:AnotherPass456
AUTH_USERS=

ENVIRONMENT=development
